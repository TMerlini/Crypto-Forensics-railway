# Etherscan V2 multichain API key (https://etherscan.io/apis).
# IMPORTANT: the FREE V2 tier only works for Ethereum mainnet + Sepolia. For
# Base / Arbitrum / Optimism / Polygon / BSC, V2 returns:
#   "Free API access is not supported for this chain. Please upgrade your api
#    plan for full chain coverage."
# Either upgrade to Etherscan Pro ($199/mo) — one key for all chains — or sign
# up for a free chain-specific key on each chain's native explorer (cheap +
# what most people do).
ETHERSCAN_API_KEY=

# Per-chain free API keys. Each one is a separate signup. Unset what you don't
# use. The server picks the right one automatically based on the chain selected
# in the UI dropdown.
# https://basescan.org/apis
BASESCAN_API_KEY=
# https://arbiscan.io/apis
ARBISCAN_API_KEY=
# https://optimistic.etherscan.io/apis
OPTIMISTIC_ETHERSCAN_API_KEY=
# https://polygonscan.com/apis
POLYGONSCAN_API_KEY=
# https://bscscan.com/apis
BSCSCAN_API_KEY=

# Target chain id. 1 = Ethereum mainnet. 8453 = Base. 42161 = Arbitrum. 10 = Optimism. 56 = BSC. 137 = Polygon.
CHAIN_ID=1

# The scam address you want to trace by default.
# (Can also be entered in the UI per-trace — this is just the default pre-filled.)
SCAM_ADDRESS=0x541b9034c82d7fb564f12ca07037947ff5b4ef2f

# Direction to crawl: "in" = backwards (who funded target), "out" = forwards
# (where money went), "both" = both directions.
DIRECTION=both

# Max recursion depth. 1 = direct counterparties only.
MAX_DEPTH=5

# Safety cap: stop after expanding this many distinct addresses.
MAX_ADDRESSES=500

# Per-endpoint row cap. If a single (address, endpoint) returns more rows than
# this we stop paginating early — protects against whale wallets OOM-ing the
# tracer on memory-limited hosts. 30k is a safe middle ground.
# ETHERSCAN_MAX_ROWS=30000

# Calls per second to Etherscan. Free tier = 5. Paid Pro = up to 30.
RATE_LIMIT_RPS=4

# Stop recursing when we hit a known CEX / bridge / mixer / contract.
STOP_AT_ORIGIN=true

# Optional time window filter. Unix seconds. Leave empty for all-time.
FROM_TIMESTAMP=
TO_TIMESTAMP=

# ------------------------------------------------------------------
# UI server (LOCAL DEV ONLY — do NOT copy these two into Railway/Render/Fly)
# ------------------------------------------------------------------
# On hosted platforms PORT is injected for you and SERVER_BIND must be 0.0.0.0
# (or unset) — leaving SERVER_BIND=127.0.0.1 in your hosted Variables makes the
# container unreachable.
SERVER_PORT=4337
SERVER_BIND=127.0.0.1

# ------------------------------------------------------------------
# Hosted-deployment settings (Railway / Render / Fly / Heroku / etc.)
# ------------------------------------------------------------------
# These only kick in when PORT is set in the environment (which all the
# platforms above do automatically). Locally you can ignore this whole block.
#
# Hosted mode behaviour:
#   - Server binds to 0.0.0.0 (all interfaces) instead of loopback
#   - DISABLE_DISK defaults to true: trace reports stream to the browser only,
#     nothing is written to disk (the FS is ephemeral anyway)
#   - The History tab returns empty
#
# REQUIRED on hosted deployments — set a strong shared password. Without it,
# anyone who finds your URL can burn your Etherscan key on traces.
AUTH_PASSWORD=
# Username paired with AUTH_PASSWORD. Defaults to "admin".
AUTH_USER=admin

# Force-disable disk writes even locally. Defaults to true on hosted platforms,
# false locally.
# DISABLE_DISK=false
